  "layer_norm_epsilon": 1e-05,
  "initializer_range": 0.02,
  "use_cache": true,
  "bos_token_id": 2,
  "eos_token_id": 3,
  "pad_token_id": 0,
  "tie_word_embeddings": true,
  "torch_dtype": "float32",
  "_comment": "Config for ~28.2M parameter GPT-Neo model trained on TinyStories with 10K vocab"
